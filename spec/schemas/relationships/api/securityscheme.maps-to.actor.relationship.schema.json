{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Securityscheme maps-to Actor",
  "description": "Defines relationship: api.securityscheme maps-to security.actor",
  "allOf": [{ "$ref": "../../base/spec-node-relationship.schema.json" }],
  "properties": {
    "id": { "const": "api.securityscheme.maps-to.security.actor" },
    "source_spec_node_id": { "const": "api.securityscheme" },
    "source_layer": { "const": "api" },
    "destination_spec_node_id": { "const": "security.actor" },
    "destination_layer": { "const": "security" },
    "predicate": { "const": "maps-to" },
    "cardinality": { "const": "many-to-one" },
    "strength": { "const": "medium" }
  }
}
