{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resource monitors Node",
  "description": "Defines relationship: apm.resource monitors technology.node",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "apm.resource.monitors.technology.node"
    },
    "source_spec_node_id": {
      "const": "apm.resource"
    },
    "source_layer": {
      "const": "apm"
    },
    "destination_spec_node_id": {
      "const": "technology.node"
    },
    "destination_layer": {
      "const": "technology"
    },
    "predicate": {
      "const": "monitors"
    },
    "cardinality": {
      "const": "many-to-one"
    },
    "strength": {
      "const": "medium"
    }
  }
}
