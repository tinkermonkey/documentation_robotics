{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Subview serves Applicationservice",
  "description": "Defines relationship: ux.subview serves application.applicationservice",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "ux.subview.serves.application.applicationservice"
    },
    "source_spec_node_id": {
      "const": "ux.subview"
    },
    "source_layer": {
      "const": "ux"
    },
    "destination_spec_node_id": {
      "const": "application.applicationservice"
    },
    "destination_layer": {
      "const": "application"
    },
    "predicate": {
      "const": "serves"
    },
    "cardinality": {
      "const": "many-to-many"
    },
    "strength": {
      "const": "medium"
    }
  }
}
