{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Route accesses Operation",
  "description": "Defines relationship: navigation.route accesses api.operation",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "navigation.route.accesses.api.operation"
    },
    "source_spec_node_id": {
      "const": "navigation.route"
    },
    "source_layer": {
      "const": "navigation"
    },
    "destination_spec_node_id": {
      "const": "api.operation"
    },
    "destination_layer": {
      "const": "api"
    },
    "predicate": {
      "const": "accesses"
    },
    "cardinality": {
      "const": "many-to-one"
    },
    "strength": {
      "const": "medium"
    }
  }
}
