{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Objectschema realizes Dataobject",
  "description": "Defines relationship: data-model.objectschema realizes application.dataobject",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "data-model.objectschema.realizes.application.dataobject"
    },
    "source_spec_node_id": {
      "const": "data-model.objectschema"
    },
    "source_layer": {
      "const": "data-model"
    },
    "destination_spec_node_id": {
      "const": "application.dataobject"
    },
    "destination_layer": {
      "const": "application"
    },
    "predicate": {
      "const": "realizes"
    },
    "cardinality": {
      "const": "many-to-many"
    },
    "strength": {
      "const": "medium"
    }
  }
}
