{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Jsonschema maps-to Artifact",
  "description": "Defines relationship: data-model.jsonschema maps-to technology.artifact",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "data-model.jsonschema.maps-to.technology.artifact"
    },
    "source_spec_node_id": {
      "const": "data-model.jsonschema"
    },
    "source_layer": {
      "const": "data-model"
    },
    "destination_spec_node_id": {
      "const": "technology.artifact"
    },
    "destination_layer": {
      "const": "technology"
    },
    "predicate": {
      "const": "maps-to"
    },
    "cardinality": {
      "const": "many-to-one"
    },
    "strength": {
      "const": "medium"
    }
  }
}
