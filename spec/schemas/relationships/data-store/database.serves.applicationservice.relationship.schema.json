{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Database serves Applicationservice",
  "description": "Defines relationship: data-store.database serves application.applicationservice",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "data-store.database.serves.application.applicationservice"
    },
    "source_spec_node_id": {
      "const": "data-store.database"
    },
    "source_layer": {
      "const": "data-store"
    },
    "destination_spec_node_id": {
      "const": "application.applicationservice"
    },
    "destination_layer": {
      "const": "application"
    },
    "predicate": {
      "const": "serves"
    },
    "cardinality": {
      "const": "many-to-one"
    },
    "strength": {
      "const": "medium"
    }
  }
}
