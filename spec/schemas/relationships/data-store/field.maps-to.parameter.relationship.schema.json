{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Field maps-to Parameter",
  "description": "Defines relationship: data-store.field maps-to api.parameter",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "data-store.field.maps-to.api.parameter"
    },
    "source_spec_node_id": {
      "const": "data-store.field"
    },
    "source_layer": {
      "const": "data-store"
    },
    "destination_spec_node_id": {
      "const": "api.parameter"
    },
    "destination_layer": {
      "const": "api"
    },
    "predicate": {
      "const": "maps-to"
    },
    "cardinality": {
      "const": "many-to-many"
    },
    "strength": {
      "const": "medium"
    }
  }
}
