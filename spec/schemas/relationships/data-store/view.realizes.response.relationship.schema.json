{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "View realizes Response",
  "description": "Defines relationship: data-store.view realizes api.response",
  "allOf": [
    {
      "$ref": "../../base/spec-node-relationship.schema.json"
    }
  ],
  "properties": {
    "id": {
      "const": "data-store.view.realizes.api.response"
    },
    "source_spec_node_id": {
      "const": "data-store.view"
    },
    "source_layer": {
      "const": "data-store"
    },
    "destination_spec_node_id": {
      "const": "api.response"
    },
    "destination_layer": {
      "const": "api"
    },
    "predicate": {
      "const": "realizes"
    },
    "cardinality": {
      "const": "many-to-one"
    },
    "strength": {
      "const": "medium"
    }
  }
}
