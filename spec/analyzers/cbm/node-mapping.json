{
  "version": "1.0",
  "field_conventions": {
    "cbm_label": "PascalCase identifier from CBM analyzer output (e.g., 'Route', 'Function')",
    "dr_layer": "canonical DR layer name (one of 12 layers)",
    "dr_element_type": "element type within the DR layer",
    "confidence": "mapping confidence level (high, medium, low)",
    "conditions.verify_role": "optional role designation for verification scope (primary, secondary, auxiliary) — nested inside conditions object",
    "conditions.evidence_fields": "array of fields from analyzer output used as evidence for mapping confidence — nested inside conditions object",
    "conditions.promotion_heuristics": "conditions and thresholds for promoting nodes to higher-level element types — nested inside conditions object"
  },
  "mappings": [
    {
      "cbm_label": "Route",
      "dr_layer": "api",
      "dr_element_type": "operation",
      "confidence": "high",
      "description": "HTTP route maps to API operation with high confidence",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "dr_element_fields": {
        "attributes": [
          {
            "dr_attribute": "operationId",
            "from": "name",
            "transform": "kebab-case"
          },
          {
            "dr_attribute": "summary",
            "from": "description",
            "default": ""
          },
          {
            "dr_attribute": "tags",
            "from": "tags",
            "template": "array",
            "default": []
          }
        ]
      },
      "conditions": {
        "verify_role": "primary"
      }
    },
    {
      "cbm_label": "Function",
      "dr_layer": "application",
      "dr_element_type": "applicationfunction",
      "confidence": "medium",
      "description": "Function maps to application function; may be promoted to service via heuristics",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "attribute_mappings": [
        {
          "from": "name",
          "dr_attribute": "name"
        }
      ],
      "conditions": {
        "promotion_eligible": true,
        "promotion_target": "applicationservice",
        "promotion_attributes": {
          "serviceType": {
            "from": "parent_class_name",
            "default": "utility"
          }
        },
        "evidence_fields": [
          "fan_in",
          "fan_out",
          "is_exported",
          "argument_types",
          "return_type"
        ]
      }
    },
    {
      "cbm_label": "Method",
      "dr_layer": "application",
      "dr_element_type": "applicationfunction",
      "confidence": "medium",
      "description": "Class method maps to application function; may be promoted to service via heuristics",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "attribute_mappings": [
        {
          "from": "name",
          "dr_attribute": "name"
        }
      ],
      "conditions": {
        "promotion_eligible": true,
        "promotion_target": "applicationservice",
        "promotion_attributes": {
          "serviceType": {
            "from": "parent_class_name",
            "default": "domain"
          }
        },
        "evidence_fields": [
          "visibility",
          "is_static",
          "is_abstract",
          "parent_class",
          "overrides"
        ]
      }
    },
    {
      "cbm_label": "Class",
      "dr_layer": "application",
      "dr_element_type": "applicationcomponent",
      "confidence": "medium",
      "description": "Class maps to application component",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "conditions": {
        "evidence_fields": [
          "abstract",
          "interfaces",
          "parent_class",
          "methods_count",
          "properties_count"
        ]
      }
    },
    {
      "cbm_label": "Module",
      "dr_layer": "application",
      "dr_element_type": "applicationcomponent",
      "confidence": "low",
      "description": "Module (file/namespace) maps to application component with low confidence",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      }
    }
  ],
  "unmapped_labels": {
    "description": "CBM node type labels that are not mapped to DR architecture model elements. These labels represent implementation-level or metadata constructs that do not have direct architectural significance in the 12-layer model.",
    "labels": [
      "Project",
      "Package",
      "Folder",
      "File",
      "Interface",
      "Enum",
      "Type"
    ]
  }
}
