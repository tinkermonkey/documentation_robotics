      "dr_scope": "cross-layer",
      "direction": "forward",
      "confidence_from_property": "is_external_endpoint",
      "dr_pattern": "api.operation -> application.applicationservice",
      "implementation_note": "Requires HTTP verb and endpoint analysis to create cross-layer reference"
    },
