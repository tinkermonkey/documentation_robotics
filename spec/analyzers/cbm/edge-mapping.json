{
  "version": "1.0",
  "field_conventions": {
    "analyzer_edge_type": "lowercase_underscore identifier from CBM analyzer output",
    "dr_relationship": "predicate name from predicates.json or null if unmappable",
    "confidence": "mapping confidence level (high, medium, low)",
    "usage": "edge classification: 'verification_and_mapping' for cross-layer edges that create DR predicates, 'traversal_only' for intra-layer edges used for semantic analysis but not mapped to DR predicates",
    "dr_scope": "scope of the relationship (intra-layer, cross-layer, both)",
    "direction": "relationship direction (forward, backward, bidirectional)",
    "confidence_from_property": "code property that determines confidence level (e.g., visibility, export status)"
  },
  "mappings": [
    {
