{
  "name": "cbm",
  "version": "0.8.3",
  "source_version": "0.8.3",
  "analyzer": {
    "name": "cbm",
    "display_name": "codebase-memory-mcp",
    "description": "Tree-sitter-based code knowledge graph server by DeusData",
    "homepage": "https://github.com/DeusData/codebase-memory-mcp",
    "mcp_server_name": "codebase-memory-mcp",
    "binary_names": ["codebase-memory-mcp"],
    "supported_tool_contract": {
      "required_tools": [
        "initialize",
        "search_graph",
        "trace_call_path",
        "get_node_details",
        "analyze_dependencies",
        "extract_metrics",
        "find_references"
      ],
      "optional_tools": [
        "batch_analyze",
        "cache_status",
        "optimize_index",
        "export_graph",
        "reset_cache"
      ]
    },
    "supported_languages": [
      "typescript",
      "javascript",
      "python",
      "java",
      "go",
      "rust",
      "c#",
      "php",
      "tsx",
      "c++",
      "lua",
      "scala"
    ],
    "known_minimum_version": null,
    "project_identification": {
      "strategy": "absolute_path",
      "description": "DR CLI passes the project root as an absolute path via findProjectRoot(). The analyzer uses this path to establish a stable project identity for consistent indexing and caching across sessions."
    },
    "notes": "Uses absolute path indexing for project identification. Ensures consistent graph generation and caching across multiple analysis runs within the same project."
  },
  "nodes_by_label": {
    "Route": {
      "cbm_label": "Route",
      "dr_layer": "api",
      "dr_element_type": "operation",
      "confidence": "high",
      "description": "HTTP route maps to API operation with high confidence",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "dr_element_fields": {
        "attributes": [
          {
            "dr_attribute": "operationId",
            "from": "name",
            "transform": "kebab-case"
          },
          {
            "dr_attribute": "summary",
            "from": "description",
            "default": ""
          },
          {
            "dr_attribute": "tags",
            "from": "tags",
            "template": "array",
            "default": []
          }
        ]
      },
      "conditions": {
        "verify_role": "primary"
      }
    },
    "Function": {
      "cbm_label": "Function",
      "dr_layer": "application",
      "dr_element_type": "applicationfunction",
      "confidence": "medium",
      "description": "Function maps to application function; may be promoted to service via heuristics",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "attribute_mappings": [
        {
          "from": "name",
          "dr_attribute": "name"
        }
      ],
      "conditions": {
        "promotion_eligible": true,
        "promotion_target": "applicationservice",
        "promotion_attributes": {
          "serviceType": {
            "from": "parent_class_name",
            "default": "utility"
          }
        },
        "evidence_fields": [
          "fan_in",
          "fan_out",
          "is_exported",
          "argument_types",
          "return_type"
        ]
      }
    },
    "Method": {
      "cbm_label": "Method",
      "dr_layer": "application",
      "dr_element_type": "applicationfunction",
      "confidence": "medium",
      "description": "Class method maps to application function; may be promoted to service via heuristics",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "attribute_mappings": [
        {
          "from": "name",
          "dr_attribute": "name"
        }
      ],
      "conditions": {
        "promotion_eligible": true,
        "promotion_target": "applicationservice",
        "promotion_attributes": {
          "serviceType": {
            "from": "parent_class_name",
            "default": "domain"
          }
        },
        "evidence_fields": [
          "visibility",
          "is_static",
          "is_abstract",
          "parent_class",
          "overrides"
        ]
      }
    },
    "Class": {
      "cbm_label": "Class",
      "dr_layer": "application",
      "dr_element_type": "applicationcomponent",
      "confidence": "medium",
      "description": "Class maps to application component",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      },
      "conditions": {
        "evidence_fields": [
          "abstract",
          "interfaces",
          "parent_class",
          "methods_count",
          "properties_count"
        ]
      }
    },
    "Module": {
      "cbm_label": "Module",
      "dr_layer": "application",
      "dr_element_type": "applicationcomponent",
      "confidence": "low",
      "description": "Module (file/namespace) maps to application component with low confidence",
      "source_reference": {
        "provenance": "extracted",
        "file": {
          "from": "file_path"
        },
        "symbol": {
          "from": "name"
        }
      }
    }
  },
  "edges_by_type": {
    "HTTP_CALLS": {
      "cbm_edge": "HTTP_CALLS",
      "dr_relationship": "consumes",
      "confidence": "high",
      "description": "HTTP API call between services maps to consumes relationship",
      "usage": "verification_and_mapping",
      "dr_scope": "cross-layer",
      "direction": "caller_to_callee",
      "confidence_from_property": "confidence",
      "dr_pattern": "application.applicationservice → api.operation",
      "implementation_note": "Requires HTTP verb and endpoint analysis to create cross-layer reference"
    },
    "HANDLES": {
      "cbm_edge": "HANDLES",
      "dr_relationship": "provides",
      "confidence": "high",
      "description": "HTTP request handler maps to provides relationship",
      "usage": "verification_and_mapping",
      "dr_scope": "cross-layer",
      "direction": "forward",
      "confidence_from_property": "handler_decorator",
      "dr_pattern": "application.applicationfunction → api.operation",
      "implementation_note": "HTTP handler decoration indicates implementation relationship"
    },
    "CALLS": {
